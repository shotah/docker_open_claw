# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Google OAuth / gws credentials (never commit)
secrets/google/*
!secrets/google/.gitkeep
!secrets/google/.gitignore

# Google Workspace MCP tokens (never commit)
secrets/google-mcp/**
!secrets/google-mcp/.gitkeep
!secrets/google-mcp/.gitignore
!secrets/google-mcp/credentials/
!secrets/google-mcp/credentials/.gitkeep
!secrets/google-mcp/credentials/.gitignore

# Strava OAuth token (never commit)
secrets/strava/*
!secrets/strava/.gitkeep
!secrets/strava/.gitignore

# Garmin Connect session (never commit)
secrets/garmin/*
!secrets/garmin/.gitkeep
!secrets/garmin/.gitignore

# Scratch HOME used for local garmin CLI smoke tests (never commit)
secrets/garmin_home_tmp/

# Generated config + ZeroClaw pairing/agent state (synced / runtime)
config/*
!config/config.toml.example
# Agent persona: commit only *.example.md templates. Live *.md are local/generated.
!config/agents/
config/agents/*
!config/agents/main/
config/agents/main/*
!config/agents/main/workspace/
config/agents/main/workspace/*
!config/agents/main/workspace/*.example.md
config/agents/main/workspace/memory/

# Workspace / memory volume
data/
!data/.gitkeep

# Docker
.docker/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*.local.*
.idea/

# Temp
tmp/
*.tmp
*.swp
*~
