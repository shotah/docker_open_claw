# Minimal ZeroClaw config — Gemini + Telegram (schema v3).
# Secrets are injected at runtime via .env / compose schema-mirror env vars.
# Synced into config/config.toml by: make sync-config
#
# Schema v3: inbound Telegram auth is peer_groups.*.external_peers
# (channel-level allowed_users was removed).

schema_version = 3

[providers.models.gemini.default]
model = "gemini-3.5-flash"
# api_key filled from GEMINI_API_KEY via ZEROCLAW_providers__models__gemini__default__api_key

[agents.main]
enabled = true
model_provider = "gemini.default"
risk_profile = "default"
runtime_profile = "telegram_lean"
channels = ["telegram.default"]
# Grant MCP servers to this agent. ZeroClaw is secure-by-default: servers in
# [mcp] are registered but only reach an agent via a bundle (see [mcp_bundles]).
mcp_bundles = ["google-workspace", "strava", "garmin", "google-search"]

# Bound Telegram session history so fat tool dumps don't poison the prompt.
# Send /new in Telegram for a hard session reset. See docs/telegram.md.
[runtime_profiles.telegram_lean]
agentic = true
max_history_messages = 40
keep_tool_context_turns = 2
max_tool_result_chars = 6000
max_tool_iterations = 12

[runtime_profiles.telegram_lean.history_pruning]
enabled = true
keep_recent = 6
max_tokens = 12000
collapse_tool_results = true

[runtime_profiles.telegram_lean.context_compression]
enabled = true
threshold_ratio = 0.35
protect_first_n = 2
protect_last_n = 6
summary_max_chars = 3000
tool_result_retrim_chars = 1500

[channels.telegram.default]
enabled = true
# bot_token filled from TELEGRAM_BOT_TOKEN via env override

# Who may talk to the agent on telegram.default (from TELEGRAM_ALLOWED_USERS)
[peer_groups.telegram_default]
channel = "telegram.default"
agents = ["main"]
external_peers = []

# Built-in google_workspace (gws) is OFF — ZeroClaw rejects camelCase methods
# like batchUpdate, so Docs writes fail. Prefer the Go MCP below.
[google_workspace]
enabled = false

# Google Workspace via magks/google-workspace-mcp-go (docs/google-workspace.md).
# Strava / Garmin / Google Search MCP servers (see their docs).
# ZeroClaw launches each binary over stdio.
[mcp]
enabled = true
# false = load MCP tool schemas eagerly so the model always sees them.
deferred_loading = false

[[mcp.servers]]
name = "google-workspace"
transport = "stdio"
command = "google-workspace-mcp-go"
# core tier ≈ 45 tools; include services Tim uses day-to-day.
args = [
  "--tools",
  "gmail drive calendar docs sheets tasks contacts",
  "--tool-tier",
  "core",
]

[[mcp.servers]]
name = "strava"
transport = "stdio"
command = "strava-mcp"

[[mcp.servers]]
name = "garmin"
transport = "stdio"
command = "garmin"
args = ["mcp"]

[[mcp.servers]]
name = "google-search"
transport = "stdio"
command = "mcp-gemini-google-search"

[mcp_bundles.google-workspace]
servers = ["google-workspace"]

[mcp_bundles.strava]
servers = ["strava"]

[mcp_bundles.garmin]
servers = ["garmin"]

[mcp_bundles.google-search]
servers = ["google-search"]

# Built-in ZeroClaw web_search defaults to DuckDuckGo scraping, which Docker IPs
# get blocked for. Prefer the google-search MCP (Gemini grounding) above.
[web_search]
enabled = false

# Web access for Tim's `web_fetch` tool. Matching is by domain (exact or
# subdomain) — no scheme, no path. `blocked_domains` ALWAYS wins over allowed.
[web_fetch]
allowed_domains = ["*"]
blocked_domains = [
]

[gateway]
host = "127.0.0.1"
port = 42617
allow_public_bind = false
require_pairing = false

[risk_profiles.default]
# Autonomy levels (ZeroClaw built-in — no custom boolean needed):
#   readonly    — observe only
#   supervised  — medium-risk tools ask / get denied on channels (default)
#   full        — no approval prompts; forbidden_paths / sandbox still apply  ← Tim
#   yolo        — nuke all gates (shell, paths, sandbox). Overkill for a bot
#                 that has Gmail + a Telegram allowlist; use only on a throwaway box.
level = "full"
auto_approve = ["*"]
